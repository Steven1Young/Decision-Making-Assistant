# Environment template for local development.
# Copy this file to .env and fill in local secrets.
# Never commit .env.

MODEL_PROVIDER=openai
OPENAI_API_KEY=
ADVISOR_MODEL=
EMBEDDING_MODEL=

# V0.1 defaults are conservative.
LOCAL_FIRST=true
ALLOW_CLOUD_LLM=false
ALLOW_SENSITIVE_UPLOAD=false

# Optional local runtime settings.
MEMORY_DIR=memory
PROMPTS_DIR=prompts
DOCS_DIR=docs
